# secrets — NEVER commit
.env
*.key
kaggle.json
.mcp-auth/

# python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.venv/
venv/

# claude / ralph local state
.claude/*.local.md
.claude/settings.local.json

# selenium scraper local data (chrome profile + raw html) — never commit
.scrape/

# Raw competition data — Kaggle ToS line 117 forbids redistribution.
competitions/*/data/raw/*
!competitions/*/data/raw/.gitkeep
!competitions/*/data/raw/README.md

# Heavy generated DATA payloads (jsonl/parquet/etc). Track the scripts, ignore outputs.
competitions/*/data/synthetic/cache/
competitions/*/data/corpus/*/corpus.jsonl
competitions/*/data/corpus/*/dev_split.jsonl
# operator-built verified corpus (contains raw prompts+gold answers) — never commit per ToS
competitions/*/data/build_v13/*.jsonl

# Other large/generated artifacts
competitions/*/references/*/
competitions/*/experiments/*/adapter/
competitions/*/submissions/**/*.zip
state/snapshots/

# transient operator scratch (decisions are replayed from events.jsonl; nb pulls are caches)
state/_decision_*.json
state/last_run_output/
state/live_notebook_*.json
# derived from raw train.csv (keyed to competition ids) — keep out of public repo per ToS
state/train_id_category.json

# os
.DS_Store
Thumbs.db
competitions/*/eval/cv_fixture*.jsonl
