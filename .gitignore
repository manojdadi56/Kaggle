# secrets — NEVER commit
.env
*.key
kaggle.json
.mcp-auth/

# python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.venv/
venv/

# claude / ralph local state
.claude/*.local.md
.claude/settings.local.json

# selenium scraper local data (chrome profile + raw html) — never commit
.scrape/

# large / generated artifacts
competitions/*/data/*
!competitions/*/data/.gitkeep
competitions/*/references/*/
competitions/*/experiments/*/adapter/
competitions/*/submissions/**/*.zip
state/snapshots/

# os
.DS_Store
Thumbs.db

# competition data — never commit (Kaggle ToS line 117 forbids redistribution)
competitions/*/data/raw/*
!competitions/*/data/raw/.gitkeep
!competitions/*/data/raw/README.md
