# Copy to .env and fill in. .env is gitignored — NEVER commit real keys.
# Rotate the keys that were pasted into chat before using them here.

# --- Jules (worker) ---
JULES_API_KEY=your-jules-api-key
JULES_SOURCE=sources/github/manojdadi56/Kaggle

# --- Kaggle (submission + GPU kernels) ---
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_KEY=your-kaggle-api-key
# Optional: Kaggle Access Token for the Kaggle MCP (agentic browsing only)
KGAT=KGAT_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Operator = the Claude Code session (your subscription). NO API key. ---
# Do NOT set ANTHROPIC_API_KEY — if set it overrides the subscription. Leave it unset.
# Only needed for the OPTIONAL unattended self-drive mode (Windows Task Scheduler ->
# `claude -p`): a subscription OAuth token from `claude setup-token` (NOT an API key):
# CLAUDE_CODE_OAUTH_TOKEN=your-oauth-token-from-claude-setup-token

# --- orchestrator settings (optional overrides) ---
ACTIVE_COMPETITION=nvidia-nemotron-model-reasoning-challenge
POLL_INTERVAL_S=60
HEARTBEAT_S=1800
CONCURRENCY_CAP=15   # confirmed PAID Jules tier (>3 concurrent verified live; Pro = 15 concurrent / 100 tasks/day)
MAX_AUTO_SUBMITS_PER_DAY=3
OPERATOR_MODEL=opus
