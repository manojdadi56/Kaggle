validation_policy:
  default_change_size: small
  override_to:
    security: large
    breaking_api: large

router:
  schedule_cadence: "90m"
  max_lock_ttl_minutes: 90

git:
  default_branch: main
  branch_prefix: sdlc/
  commit_audit_tag: "[sdlc-owner]"
