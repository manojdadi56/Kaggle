# SDLC project configuration
project_id: PROJECT-PLACEHOLDER
project_name: "Human-readable project name"
created_at: "2026-05-08T00:00:00Z"
status: ACTIVE
cadence: "90m"

phases:
  - id: PHASE-001
    title: "Initial setup"
    goal: "Establish baseline and ship first vertical slice."

metrics_policy:
  collect:
    - flow.cycle_time
    - quality.review_findings_per_task
    - test.coverage_delta
